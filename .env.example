# === 祇園家園：全透明、不隱藏、公益核心配置 ===

# 1. 您的家園總目錄 (Finder 一眼就能看到的資料夾)
HERMES_HOME=~/Hermes_Gion_Core

# 2. 核心大腦設定檔 (存放您對 AI 的規則與模型設定)
HERMES_CONFIG_PATH=~/Hermes_Gion_Core/config.yaml

# 3. 生命之書保存區 (對話紀錄與記憶，強制存於此)
HERMES_WEBUI_STATE_DIR=~/Hermes_Gion_Core/webui_history

# 4. 公益網站工作區 (預設開啟此資料夾)
HERMES_WEBUI_DEFAULT_WORKSPACE=~/Hermes_Gion_Core/Public_Welfare_Project

# 5. 守護者的名字 (介面顯示名稱)
HERMES_WEBUI_BOT_NAME=Gion_守護者

# 6. 家園存取權限 (開啟區域網路共享)
# 設定為 0.0.0.0 代表允許家中的手機、平板透過 Wi-Fi 直接連線存取
HERMES_WEBUI_HOST=0.0.0.0
