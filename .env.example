# Gion Local Core example environment.
# Copy to .env before local use. Do not commit .env.

# Transparent host data root. Keep all persistent data here.
HERMES_HOME=~/Hermes_Gion_Core

# Host workspace mounted into the Docker container at /workspace.
HERMES_WORKSPACE=~/Hermes_Gion_Core/Public_Welfare_Project

# Host-side default workspace used by bootstrap.py. Docker overrides the
# container value to /workspace so the WebUI sees the mounted workspace path.
HERMES_WEBUI_DEFAULT_WORKSPACE=~/Hermes_Gion_Core/Public_Welfare_Project

# Host-side state/history path used by bootstrap.py.
# Docker maps this under /home/hermeswebui/.hermes/webui_history.
HERMES_WEBUI_STATE_DIR=~/Hermes_Gion_Core/webui_history

# Display name.
HERMES_WEBUI_BOT_NAME=Gion_守護者

# Container-internal binding. docker-compose.yml still publishes localhost-only.
HERMES_WEBUI_HOST=0.0.0.0
HERMES_WEBUI_PORT=8787

# Optional: set only if you intentionally expose the service beyond localhost.
# HERMES_WEBUI_PASSWORD=

# Recommended when bind-mounting existing host directories.
# UID=1000
# GID=1000

# Optional host-side WebUI source tree for ./start.sh / bootstrap.py --foreground.
# Leave unset for the canonical Docker image flow. If you keep WebUI source
# outside this launcher/config repo, point this at that tree, for example:
# HERMES_WEBUI_SOURCE_DIR=/Users/max/hermes-webui
